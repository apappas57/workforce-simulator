# .env.example
#
# Copy this file to .env and fill in the values below.
# NEVER commit .env — it is listed in .gitignore.

# ── Deployment key ────────────────────────────────────────────────────────────
# A signed deployment key issued by the tool administrator (Alex).
# Required to start the app. Contact the administrator to obtain a key.
# Keys are per-organisation and may have an expiry date.

DEPLOYMENT_KEY=your_deployment_key_here

# ── Cloud deployment: credentials (Railway / Render / any Docker host) ────────
#
# When auth/credentials.yaml cannot be volume-mounted (e.g. on cloud platforms
# that don't support arbitrary file mounts), supply the YAML content as a
# base64-encoded string in this variable instead.
#
# The app checks for auth/credentials.yaml first; if it doesn't exist it falls
# back to this variable.  If neither is set, the app runs without authentication
# (development / local mode).
#
# Generate the value from an existing credentials.yaml:
#
#   macOS / Linux:
#     base64 -i auth/credentials.yaml | tr -d '\n'
#
#   Or Python (any platform):
#     python -c "import base64, pathlib; \
#       print(base64.b64encode(pathlib.Path('auth/credentials.yaml').read_bytes()).decode())"
#
# Paste the output (a long single-line string) as the value below.

CREDENTIALS_YAML_B64=
