# auth/credentials.yaml.example
#
# Copy this file to auth/credentials.yaml and fill in your own values.
# NEVER commit credentials.yaml — it is listed in .gitignore.
#
# Managing passwords
# ------------------
# Passwords must be stored as bcrypt hashes, not plain text.
# To generate a hash for a new password, run:
#
#   python - <<'EOF'
#   import bcrypt
#   pw = input("Password: ").encode()
#   print(bcrypt.hashpw(pw, bcrypt.gensalt()).decode())
#   EOF
#
# Or, if streamlit-authenticator is installed:
#
#   python -c "import streamlit_authenticator as a; print(a.Hasher(['mypassword']).generate())"
#
# Adding users
# ------------
# Add an entry under credentials.usernames for each user.
# The key (e.g. "jsmith") is the login username.
#
# Cookies
# -------
# cookie.key  — a long random secret used to sign the browser cookie.
#               Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# cookie.name — an arbitrary name for the cookie (no spaces).
# cookie.expiry_days — how many days the login persists before the user must re-authenticate.

credentials:
  usernames:
    analyst1:
      email: analyst1@yourorg.com
      name: Analyst One
      password: "$2b$12$REPLACE_WITH_BCRYPT_HASH_OF_PASSWORD"
    analyst2:
      email: analyst2@yourorg.com
      name: Analyst Two
      password: "$2b$12$REPLACE_WITH_BCRYPT_HASH_OF_PASSWORD"

cookie:
  expiry_days: 30
  key: "REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING"
  name: "workforce_sim_auth"
